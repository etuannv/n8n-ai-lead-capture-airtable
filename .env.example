# =============================================================
# n8n AI Lead Capture — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit .env to git (already in .gitignore).
# =============================================================

# Anthropic API Key
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Telegram Bot Token
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Chat ID
# Get yours by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=123456789

# Airtable Personal Access Token
# Create at: airtable.com → Developer Hub → Personal access tokens
# Required scopes: data.records:write, schema.bases:read, schema.bases:write
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX

# Airtable Base ID (from URL: airtable.com/appXXX/...)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Airtable Table ID (from URL: airtable.com/appXXX/tblXXX/...)
AIRTABLE_TABLE_ID=tblXXXXXXXXXXXXXX

# =============================================================
# NOTE: All credentials above are stored securely inside n8n
# (encrypted with N8N_ENCRYPTION_KEY).
# This file is for reference only.
# =============================================================
